# Required: Gemini API key
GEMINI_API_KEY=put_your_gemini_api_key_here

# Required: Firebase Storage bucket name (exactly as shown in Firebase Console)
FIREBASE_STORAGE_BUCKET=put_your_bucket_name_here

# Optional runtime config
PORT=8080
GEMINI_MODEL=gemini-2.5-flash-image
CLIENT_DIST_DIR=../client/dist
PUBLIC_APP_URL=
FIRESTORE_DATABASE_ID=(default)
SHOPS_COLLECTION=shops
LEADS_COLLECTION=leads

# Optional SMTP (required only if you want lead emails enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=WrapPilot

# Optional for local dev if not using gcloud ADC login:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
