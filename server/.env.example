# Required: Gemini API key
GEMINI_API_KEY=put_your_gemini_api_key_here

# Required: Firebase Storage bucket name (exactly as shown in Firebase Console)
FIREBASE_STORAGE_BUCKET=put_your_bucket_name_here

# Optional
GEMINI_MODEL=gemini-2.5-flash-image
PORT=8080
CLIENT_DIST_DIR=../client/dist

# Optional for local dev if not using gcloud ADC login:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
